<html>
  <head>
    <title>Mini Messageboard</title>
  </head>
  <body>
    <h1><%= title %></h1>

    <ul>
      <% messages.forEach((message, index) => { %>
          <li>
              <strong><%= message.user %>:</strong> <%= message.text %>
              <a href="/message/<%= index %>">[Open]</a>
          </li>
      <% }); %>
  </ul>

    <a href="/new">Add a new message</a>
</body>
</html>
